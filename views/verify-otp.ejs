<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify Email - ur.url</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <script>
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
    </script>
</head>
<body>
    <header>
        <div class="navbar">
            <a href="/" class="logo">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 1.8rem; height: 1.8rem; color: var(--primary);">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
                <span>ur.url</span>
            </a>
            <div class="nav-actions">
                <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle Dark/Light theme">
                    <svg class="sun-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m2.828 0l-.707-.707M17.657 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                    </svg>
                    <svg class="moon-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                </button>
            </div>
        </div>
    </header>

    <div class="auth-container">
        <div class="card auth-card">
            <h1 class="auth-title">Verify Your Email</h1>
            <p class="auth-subtitle">We have sent a 6-digit One-Time Password (OTP) to <strong style="color: var(--text-main);"><%= email %></strong>.</p>

            <% if (error) { %>
                <div class="alert alert-danger">
                    <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 10 2 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                    <span><%= error %></span>
                </div>
            <% } %>
            <% if (msg) { %>
                <div class="alert alert-success">
                    <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span><%= msg %></span>
                </div>
            <% } %>

            <form action="/user/verify-otp" method="POST">
                <input type="hidden" name="email" value="<%= email %>">
                
                <div class="form-group">
                    <label class="form-label" for="otp">Enter 6-Digit OTP Code</label>
                    <div class="input-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                        <input class="input-field" type="text" id="otp" name="otp" placeholder="123456" pattern="[0-9]{6}" maxlength="6" style="letter-spacing: 0.25em; font-size: 1.25rem; font-weight: 700; text-align: center; padding-left: 1rem;" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-full" style="margin-top: 1.5rem;">Verify & Log In</button>
            </form>

            <p style="text-align: center; margin-top: 2rem; color: var(--text-muted); font-size: 0.95rem;">
                Didn't receive the email? 
                <a href="/user/resend-otp?email=<%= encodeURIComponent(email) %>" style="font-weight: 600;" id="resend-link">Resend Code</a>
            </p>
        </div>
    </div>

    <script>
        const toggleBtn = document.getElementById('theme-toggle');
        toggleBtn.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const targetTheme = currentTheme === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', targetTheme);
            localStorage.setItem('theme', targetTheme);
        });

        // 2-Minute Resend OTP Timer
        const email = "<%= email %>";
        const resendLink = document.getElementById('resend-link');
        const timerKey = `otp_resend_expiry_${encodeURIComponent(email)}`;
        
        let expiry = localStorage.getItem(timerKey);
        const now = Date.now();
        
        if (!expiry || parseInt(expiry) < now) {
            // Set new 2-minute timer from current load
            expiry = now + 2 * 60 * 1000;
            localStorage.setItem(timerKey, expiry);
        } else {
            expiry = parseInt(expiry);
        }

        let countdownInterval;

        function updateTimer() {
            const current = Date.now();
            const diff = expiry - current;
            
            if (diff <= 0) {
                clearInterval(countdownInterval);
                resendLink.style.pointerEvents = 'auto';
                resendLink.style.opacity = '1';
                resendLink.style.cursor = 'pointer';
                resendLink.innerText = 'Resend Code';
                localStorage.removeItem(timerKey);
            } else {
                resendLink.style.pointerEvents = 'none';
                resendLink.style.opacity = '0.6';
                resendLink.style.cursor = 'not-allowed';
                const minutes = Math.floor(diff / 60000);
                const seconds = Math.floor((diff % 60000) / 1000);
                resendLink.innerText = `Resend Code in ${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }
        }

        // Run immediately and start interval
        updateTimer();
        countdownInterval = setInterval(updateTimer, 1000);

        // Reset timer expiry when clicked
        resendLink.addEventListener('click', (e) => {
            const current = Date.now();
            if (expiry > current) {
                e.preventDefault();
                return;
            }
            // Set next cooldown expiry with 5s network/redirect buffer
            localStorage.setItem(timerKey, Date.now() + 2 * 60 * 1000 + 5000);
            resendLink.style.pointerEvents = 'none';
            resendLink.innerText = 'Sending...';
        });
    </script>
</body>
</html>
